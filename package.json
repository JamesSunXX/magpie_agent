    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "openai": "^6.16.0",
    "ora": "^9.1.0",
    "readline": "^1.3.0",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/marked-terminal": "^6.1.1",
